# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database (localhost for local dev, Docker overrides to 'db')
DB_NAME=drf_cart_pro
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis (localhost for local dev, Docker overrides to 'redis')
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL (for Stripe redirect URLs)
FRONTEND_URL=http://localhost:5173
